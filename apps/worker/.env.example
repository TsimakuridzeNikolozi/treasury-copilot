# First-time setup:
#   mkdir -p keys
#   solana-keygen new -o ./keys/treasury.json --no-bip39-passphrase
#
# Then fund the treasury (Kamino is mainnet-only):
#   - Send ~0.05 SOL (covers ~10,000 tx fees) and at least 5 USDC from any
#     wallet/CEX to: $(solana address -k ./keys/treasury.json)
#   - The USDC ATA is auto-created on first transfer by most wallets;
#     fallback: spl-token create-account EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v -u mainnet-beta
#   - Verify: solana balance -u mainnet-beta <treasury>
#             spl-token balance EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v -u mainnet-beta --owner <treasury>

DATABASE_URL=postgresql://copilot:copilot@localhost:5432/treasury

# Mainnet RPC. The free public endpoint is rate-limited; for sustained dev
# work, use a free Helius or Triton key.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
LOG_LEVEL=info

# Telegram approval bot.
# Approval routing is per-treasury (PR 3+): the chat id and approver user
# ids live on each treasury row, configured by the treasury owner via
# /settings → Telegram. The worker reads them per-action.
# 1. Create a bot via @BotFather and paste the token below.
# 2. Add the bot to each treasury's approval chat (group or 1:1) so it can
#    post / edit messages there.
TELEGRAM_BOT_TOKEN=

# How often the worker scans for new pending actions (ms). Default 5000.
# ACTION_POLL_INTERVAL_MS=5000

# How often the executor scans for newly-approved actions to run (ms). Default 3000.
# EXECUTOR_POLL_INTERVAL_MS=3000

# --- Signer config -----------------------------------------------------------
#
# Two backends:
#   local   — reads a Solana CLI keypair file off disk. Fine for dev/tests.
#   turnkey — delegates signing to Turnkey's HSM-backed API. Use for staging
#             and prod; keys never leave hardware.
#
# Default is `local` so a fresh clone boots without Turnkey credentials.
# When switching to turnkey, drain the local treasury back to a CEX/cold wallet
# first and fund the new Turnkey wallet from there — there is no key import.
SIGNER_BACKEND=local

# --- Local backend (required when SIGNER_BACKEND=local) ----------------------
SOLANA_KEYPAIR_PATH=./keys/treasury.json

# --- Turnkey backend (required when SIGNER_BACKEND=turnkey) ------------------
# Parent Turnkey API creds. Per-user treasuries (sub-orgs + wallets) are
# provisioned automatically by the web app at first sign-in; the worker
# uses these parent creds to authenticate and to look up sub-org-scoped
# wallets at sign time. organizationId and signWith are read from the
# treasuries row, not from env.
# One-time setup:
#  1. Create a Turnkey root organization at app.turnkey.com.
#  2. Create an API key pair (P-256). Public/private keys are hex; the leading
#     0x is tolerated.
#  3. Add a permissive policy that lets the parent API key administer sub-orgs
#     (the web side mints one per user via @tc/turnkey-admin).
# TURNKEY_API_PUBLIC_KEY=
# TURNKEY_API_PRIVATE_KEY=
# TURNKEY_BASE_URL=https://api.turnkey.com # default
# SIGNER_SIGN_TIMEOUT_MS=10000             # cap on a single Turnkey API call

# --- Shared signer settings --------------------------------------------------
# Commitment level to wait for before marking an action `executed`. One of:
# processed | confirmed | finalized. Default `confirmed` (~400ms, basically reliable).
# Use `finalized` (~13s) for higher-value mainnet flows.
# SIGNER_COMMITMENT=confirmed

# Hard timeout (ms) for confirmation. Without this, a stalled RPC could leave
# an action stuck `executing` forever. Default 60000.
# SIGNER_CONFIRM_TIMEOUT_MS=60000

{
  "name": "@tc/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node --env-file=.env dist/index.mjs",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "smoke:notify": "tsx --env-file=.env src/scripts/test-notification.ts",
    "smoke:yield-drift": "tsx --env-file=.env src/scripts/check-yield-drift.ts",
    "smoke:idle-capital": "tsx --env-file=.env src/scripts/check-idle-capital.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@tc/db": "workspace:*",
    "@tc/env": "workspace:*",
    "@tc/policy": "workspace:*",
    "@tc/protocols": "workspace:*",
    "@tc/signer": "workspace:*",
    "@tc/types": "workspace:*",
    "decimal.js": "^10.4.3",
    "grammy": "^1.42.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tc/tsconfig": "workspace:*",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}

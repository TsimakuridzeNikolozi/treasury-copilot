# Server-only
DATABASE_URL=postgresql://copilot:copilot@localhost:5432/treasury
SOLANA_RPC_URL=https://api.devnet.solana.com
# Used by the seed script (`pnpm db:seed-m2`) only — it auto-loads this
# file, reads TREASURY_PUBKEY_BASE58 directly via process.env, and writes
# the seed treasury row with that wallet. Web no longer reads this var
# (PR 4 dropped the @tc/env schema). Safe to omit if you've already run
# the seed once.
TREASURY_PUBKEY_BASE58=
LOG_LEVEL=info

# AI provider — pick one of: anthropic | openai
MODEL_PROVIDER=anthropic

# Anthropic (only required if MODEL_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (only required if MODEL_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Privy (auth provider). Get both values from https://dashboard.privy.io
# under Configuration > App settings > Basics. Secret is shown once on app
# creation and cannot be recovered — regenerate if lost.
PRIVY_APP_SECRET=

# --- Signer + Turnkey-admin --------------------------------------------------
# Mirrors the worker. `local` means the worker signs with a keypair off disk,
# and the web bootstrap attaches new users to the seed treasury (no Turnkey
# call). `turnkey` means the worker signs via Turnkey HSM and the web
# bootstrap mints a per-user sub-org via @tc/turnkey-admin. The three
# TURNKEY_PARENT_* vars below are required only when SIGNER_BACKEND=turnkey.
SIGNER_BACKEND=local

# Parent-org admin API key (P-256 hex, leading 0x tolerated) and parent
# org UUID. Distinct from the runtime per-org TURNKEY_* keys the worker
# uses to sign transactions — these mint sub-orgs underneath the parent.
# TURNKEY_PARENT_ORG_ID=
# TURNKEY_PARENT_API_PUBLIC_KEY=
# TURNKEY_PARENT_API_PRIVATE_KEY=
# TURNKEY_PARENT_BASE_URL=https://api.turnkey.com  # default

# Public (shipped to browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRIVY_APP_ID=
# Optional. The Telegram bot's @username (without the leading @). Shown in
# /settings → Telegram so users can copy it when adding the bot to their
# approval group. If unset, the setup guide shows generic instructions.
# Public because the @username is public on Telegram; only the token (in
# apps/worker/.env) must stay private.
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=TreasuryCopilotBot

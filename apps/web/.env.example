# Server-only
DATABASE_URL=postgresql://copilot:copilot@localhost:5432/treasury
SOLANA_RPC_URL=https://api.devnet.solana.com
# Treasury wallet pubkey (base58). Read tools default to this address when
# the chat asks about positions/APYs without specifying one.
TREASURY_PUBKEY_BASE58=
# M2: seed treasury id (uuid). Populated by `pnpm db:seed-m2` — copy the
# UUID it prints into this var. PR 2 stops requiring this once
# membership-aware lookup ships; PR 4 removes the var entirely.
SEED_TREASURY_ID=
LOG_LEVEL=info

# AI provider — pick one of: anthropic | openai
MODEL_PROVIDER=anthropic

# Anthropic (only required if MODEL_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (only required if MODEL_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Privy (auth provider). Get both values from https://dashboard.privy.io
# under Configuration > App settings > Basics. Secret is shown once on app
# creation and cannot be recovered — regenerate if lost.
PRIVY_APP_SECRET=

# Public (shipped to browser)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRIVY_APP_ID=
